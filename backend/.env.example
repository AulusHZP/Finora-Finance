# Server Configuration
PORT=4000
NODE_ENV=development

# Database Connection (Default port mapped by docker-compose is 5433 on localhost)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/finora_auth?schema=public

# Authentication
# IMPORTANTE: Em produção, use um secret forte gerado por: openssl rand -base64 32
JWT_SECRET=super_secret_jwt_key_finora_finance
JWT_EXPIRES_IN=1d
# Validade do refresh token (sessão "lembrar de mim"), em dias
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_SALT_ROUNDS=12

# CORS Configuration
# IMPORTANTE: Em produção (NODE_ENV=production), CORS_ORIGIN é OBRIGATÓRIO.
# Sem ele, todas as requisições de navegador são negadas. Liste as URLs do
# frontend separadas por vírgula, ex: https://meuapp.com,https://www.meuapp.com
CORS_ORIGIN=http://localhost:8080,http://localhost:8081
